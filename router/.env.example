# Jarvis Router — Environment Variables
# Copy this to .env and fill in your values

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token

# OpenAI API key — OPTIONAL.
# Only needed if you want the Mem0 conversation-memory service enabled.
# ChromaDB document memory runs locally (all-MiniLM-L6-v2) with no key.
# The router works fine without this key — Mem0 will simply be unavailable,
# and memory.ts degrades gracefully.
# OPENAI_API_KEY=sk-your-openai-key
