# Jarvis Router — Environment Variables
# Copy this to .env and fill in your values.

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Discord bot token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your_discord_bot_token

# (Optional) Override the URL of the local conversation-memory server.
# Default: http://localhost:3343
# MEMORY_URL=http://localhost:3343

# (Optional) Moondream Cloud API key for the `vision-local` capability.
# Get one at https://moondream.ai (Personal tier is free, $5/mo credit).
# When set, vision-local routes to the cloud (Moondream 3, ~0.5-1.1s,
# ~$0.000068/image). When unset, falls back to the local Moondream
# Station daemon on :2020 (Moondream 2, ~3-4s, free, fully offline).
# MOONDREAM_API_KEY=eyJhbGciOi...
