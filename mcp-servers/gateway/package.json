{
  "name": "mcp-hot-gateway",
  "version": "1.0.0",
  "description": "An MCP server that mounts and unmounts other MCP servers at runtime — the agent calls mount/unmount itself, child tools appear instantly via tools/list_changed, no session restart, no config edit.",
  "type": "module",
  "bin": {
    "mcp-hot-gateway": "index.mjs"
  },
  "main": "index.mjs",
  "files": [
    "index.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node index.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-gateway",
    "mcp-proxy",
    "mcp-aggregator",
    "dynamic",
    "hot-reload",
    "list-changed",
    "claude",
    "anthropic",
    "llm",
    "agent",
    "tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zorahrel/mcp-hot-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/zorahrel/mcp-hot-gateway/issues"
  },
  "homepage": "https://github.com/zorahrel/mcp-hot-gateway#readme",
  "license": "MIT",
  "author": "Attilio Cianci",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
