# Dependencies
node_modules/
dist/

# Secrets
.env
router/.env

# Personal data (create your own from examples)
config.yaml
router/config.yaml
agents/

# Runtime data
memory/
state/
**/moondream-env/
**/*-venv/
**/__pycache__/
media/
logs/
data/
router/wa-auth/
router/certs/
router/data/
# Local-sessions monitor runtime dirs — created by the hooks installer at
# $HOME/.claude/jarvis/{events,hooks}, which lands inside the repo when it's
# cloned as ~/.claude/jarvis. Anchored to repo root to avoid masking
# `router/dashboard/src/hooks/` (which IS source code).
/events/
/hooks/
router/logs/
router/cli-sessions.json
router/session-stats.json
router/*.pid
router/cron/
chroma-data/
mem0-data/
stats.json

# Local Claude settings (never commit)
.claude/settings.local.json
**/.claude/settings.local.json

# Playwright MCP artifacts
.playwright-mcp/

# Private analysis notes
research/

# Backup files
*.bak

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.idea/
.vscode/

# Screenshots (keep docs/images/ if present)
*.png
!docs/images/*.png

# OMEGA venv — not committed (users install locally)
router/scripts/omega-env/

# Memory migration artefacts (contain real user data)
docs/migration/mem0-export-*.json
docs/migration/omega-export-*.json
docs/migration/chroma-full-*.json
mem0-history.db

# Local promo/marketing material
promo/
active-sessions/

# ─── Security hardening (2026-05-11) ──────────────────────────────────────────
# MCP Auth Manager creates daily backups of OAuth credentials. These MUST NEVER
# be committed. The backup service in v3.1+ writes to ~/Library/Application
# Support/jarvis/auth-backups/ instead of inside the repo, but keep this guard
# in case someone copies an old version of the code.
backups/
auth-backups/
*.credentials.json
mcp-needs-auth-cache*.json
.mcp-auth/

# Token files of any kind
*token*.json
*credential*.json
relocated-mcp/
